zotero:
  enabled: true
  db_path: "~/Zotero/zotero.sqlite"
  lookback_days: 7
  high_priority_collections:
    - Agent
    - RAG
    - LLM
  # 是否启用 Zotero tag 回写（会修改 Zotero 条目，请先用 CLI dry-run 测试）
  writeback_enabled: false

obsidian:
  enabled: false
  inbox_path: "~/ObsidianVault/00-Inbox/inbox.md"
  vault_path: "~/ObsidianVault"

github_stars:
  enabled: false
  mode: "passive_index"
